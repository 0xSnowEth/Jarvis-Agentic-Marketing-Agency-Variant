[Unit]
Description=Jarvis FastAPI service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/snowaflic/agents
EnvironmentFile=/home/snowaflic/agents/.env
ExecStart=/home/snowaflic/agents/venv/bin/python3 -m uvicorn webhook_server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
TimeoutStopSec=20
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
