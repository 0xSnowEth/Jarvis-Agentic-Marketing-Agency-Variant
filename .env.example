OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

WHATSAPP_MODEL=openai/gpt-4o-mini
TRIAGE_MODEL=openai/gpt-4o-mini
SYNTHESIZER_MODEL=qwen/qwen3.6-plus-preview:free
TREND_DOSSIER_MODEL=openai/gpt-4o-mini
CAPTION_MODEL=llama-3.1-8b-instant
CAPTION_FALLBACK_MODEL=qwen/qwen3.6-plus-preview:free
CAPTION_RESPONSE_MAX_TOKENS=220
# Free-first runtime: keep multimodal analysis on heuristic/local until you intentionally switch to premium vision.
VISION_ANALYSIS_MODE=heuristic
# Optional paid upgrade path for later production swaps.
ANTHROPIC_CAPTION_MODEL=claude-3-7-sonnet-latest
ANTHROPIC_VISION_MODEL=claude-3-7-sonnet-latest
TREND_RESEARCH_RECENCY_DAYS=30
TREND_DOSSIER_TTL_SECONDS=86400

META_GRAPH_VERSION=v22.0

WHATSAPP_TOKEN=your_agency_whatsapp_token
WHATSAPP_TEST_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WEBHOOK_VERIFY_TOKEN=jarvis_webhook_secret_2026
OWNER_PHONE=96560396543
WEBHOOK_PROXY_URL=https://your-public-webhook.example.com
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_OAUTH_PUBLIC_BASE_URL=https://your-public-webhook.example.com
META_OAUTH_REDIRECT_URI=https://your-public-webhook.example.com/api/meta-oauth-callback

JARVIS_ADMIN_PASSWORD=change_me_for_demo_or_production
JARVIS_SESSION_TTL_HOURS=12

JARVIS_DATA_BACKEND=json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ASSET_BUCKET=client-assets
# Optional: stable public media host for publish-grade delivery later
# PUBLISH_MEDIA_BASE_URL=https://your-domain.com

# Demo fallback for Instagram image posts on temporary hosts.
# Leave as auto to mirror image assets away from trycloudflare/supabase hosts when needed.
INSTAGRAM_IMAGE_MIRROR_MODE=auto
